# ── Flask ──────────────────────────────────────────────────────────────
FLASK_ENV=production          # development | production
SECRET_KEY=change_me_in_prod
PORT=5000

# ── CORS ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
ALLOWED_ORIGINS=http://localhost:3000,https://yourapp.com

# ── Google Drive auth (choose ONE) ─────────────────────────────────────
# Option A — path to a service account JSON file
GOOGLE_SERVICE_ACCOUNT_FILE=/secrets/service-account.json

# Option B — raw JSON string (useful for Docker / cloud envs)
GOOGLE_SERVICE_ACCOUNT_JSON={"installed":{"client_id":"593365754059-1agii2ciap7in94a8qo6i6kva5uh2fm6.apps.googleusercontent.com","project_id":"abiding-arch-456107-t7","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs"}}

# ── Upload ─────────────────────────────────────────────────────────────
UPLOAD_FOLDER=/tmp/gdrive_uploads
MAX_UPLOAD_MB=100
